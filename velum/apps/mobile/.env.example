# Variables CLIENT — publiques, non secrètes (§15.5).
# Les secrets (LLM, Numista, Artprice, eBay, FX, Qdrant, RevenueCat secret…)
# ne vivent QUE dans les Edge Functions Supabase : `supabase secrets set`.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Clés API publiques RevenueCat (une par plateforme — publiques par conception)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxx
