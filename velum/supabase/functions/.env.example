# Secrets SERVEUR uniquement (§15.5) — à poser via `supabase secrets set --env-file .env`.
# JAMAIS dans le client, JAMAIS dans EXPO_PUBLIC_* (§12.1).

# ── LLM vision (recognize / analyze-*) ──────────────────────────────────────
LLM_VISION_API_KEY=
LLM_VISION_PROVIDER=anthropic
# Modèle utilisé par AnthropicVision (défaut : claude-sonnet-5).
LLM_VISION_MODEL=

# ── Cron interne (price-cron) — même valeur que vault.secrets 'cron_secret' ─
CRON_SECRET=

# ── Webhook RevenueCat (sync profiles.plan) — en-tête Authorization Bearer ──
REVENUECAT_WEBHOOK_SECRET=

# ── Sources de prix : pièces (coin) ─────────────────────────────────────────
NUMISTA_API_KEY=
PCGS_API_KEY=
NGC_API_KEY=
HERITAGE_API_KEY=
CGB_API_KEY=

# ── Sources de prix : art ───────────────────────────────────────────────────
ARTPRICE_API_KEY=
ARTSY_API_KEY=
DROUOT_API_KEY=
MAGNUS_API_KEY=

# ── Sources de prix : timbres (stamp) ───────────────────────────────────────
COLNECT_API_KEY=
YVERT_API_KEY=
DELCAMPE_API_KEY=

# ── Sources de prix : marketplaces partagées ────────────────────────────────
EBAY_API_KEY=
CATAWIKI_API_KEY=

# ── Sources de prix : vin (wine) ────────────────────────────────────────────
WINE_SEARCHER_API_KEY=
IDEALWINE_API_KEY=
VIVINO_API_KEY=
CAVISSIMA_API_KEY=

# ── Divers ──────────────────────────────────────────────────────────────────
FX_API_KEY=
QDRANT_URL=
QDRANT_API_KEY=
