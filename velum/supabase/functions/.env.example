# Secrets SERVEUR uniquement (§15.5) — à poser via `supabase secrets set --env-file .env`.
# JAMAIS dans le client, JAMAIS dans EXPO_PUBLIC_* (§12.1).

# ── LLM vision (recognize / analyze-*) ──────────────────────────────────────
# Fournisseur multi-clé : choisis-en UN et pose sa clé dans LLM_VISION_API_KEY.
#   anthropic → Claude Messages        (modèle défaut : claude-sonnet-5)
#   openai    → Chat Completions       (modèle défaut : gpt-5.5)
#   google    → Gemini generateContent (modèle défaut : gemini-3.5-flash)
LLM_VISION_PROVIDER=anthropic
LLM_VISION_API_KEY=
# Facultatif : force un modèle précis, sinon le défaut du fournisseur ci-dessus.
LLM_VISION_MODEL=

# ── Cron interne (price-cron) — même valeur que vault.secrets 'cron_secret' ─
CRON_SECRET=

# ── Webhook RevenueCat (sync profiles.plan) — en-tête Authorization Bearer ──
REVENUECAT_WEBHOOK_SECRET=

# ── Sources de prix : pièces (coin) ─────────────────────────────────────────
NUMISTA_API_KEY=
PCGS_API_KEY=
NGC_API_KEY=
HERITAGE_API_KEY=
CGB_API_KEY=

# ── Sources de prix : art ───────────────────────────────────────────────────
ARTPRICE_API_KEY=
ARTSY_API_KEY=
DROUOT_API_KEY=
MAGNUS_API_KEY=

# ── Sources de prix : timbres (stamp) ───────────────────────────────────────
COLNECT_API_KEY=
YVERT_API_KEY=
DELCAMPE_API_KEY=

# ── Sources de prix : marketplaces partagées ────────────────────────────────
EBAY_API_KEY=
CATAWIKI_API_KEY=

# ── Sources de prix : vin (wine) ────────────────────────────────────────────
WINE_SEARCHER_API_KEY=
IDEALWINE_API_KEY=
VIVINO_API_KEY=
CAVISSIMA_API_KEY=

# ── Sources de prix : montres (watch) ───────────────────────────────────────
# Une clé ne suffit PAS à activer une source partenaire. Positionner le drapeau
# correspondant à true uniquement après confirmation écrite que le contrat
# couvre cet endpoint et l'affichage des données dans VELUM.
WATCHCHARTS_API_KEY=
WATCHCHARTS_APP_LICENSED=false

# Heritage/Catawiki/Chrono24 : intégrations partenaires désactivées tant que le
# contrat et le schéma d'API ne sont pas confirmés pour le projet.
HERITAGE_WATCH_API_ENABLED=false
CATAWIKI_WATCH_API_ENABLED=false
CHRONO24_API_KEY=
CHRONO24_WATCH_API_ENABLED=false

# eBay Marketplace Insights est un accès restreint : true uniquement pour un
# compte déjà approuvé par eBay sur cette API.
EBAY_MARKETPLACE_INSIGHTS_ENABLED=false

# ── Divers ──────────────────────────────────────────────────────────────────
FX_API_KEY=
QDRANT_URL=
QDRANT_API_KEY=
